# 朔知 · 环境变量
#
# /api/interpret(LLM 个性化解读层)使用智谱 BigModel GLM-4.6 通过 OpenAI 兼容接口。
# 缺失 BIGMODEL_API_KEY 时, /api/interpret 返回 503, 客户端无声 fallback 到
# 规则模板(lib/interpret.ts), 不影响其他功能。

# 必填: 智谱 BigModel API key
# 申请: https://open.bigmodel.cn/usercenter/apikeys
BIGMODEL_API_KEY=your_key_here

# 可选: 自定义 endpoint(默认即 BigModel 官方)
# BIGMODEL_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 可选: 切换模型(默认 glm-4.6, 也可用 glm-4.5 / glm-4.5-air / glm-4-plus)
# BIGMODEL_MODEL=glm-4.6
